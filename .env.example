# ============================================================
# App Registro — Variables de entorno
# Copiar este archivo como .env y completar con valores reales
# NUNCA committear el archivo .env real
# ============================================================

# App
APP_PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# Seguridad
BCRYPT_ROUNDS=10

# JWT (cambiar en producción por valores aleatorios largos)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_RANDOM_256_BITS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_IN_PRODUCTION_USE_RANDOM_256_BITS
JWT_REFRESH_EXPIRES_IN=7d

# Base de datos - Seguridad
SEGURIDAD_DB_HOST=your-supabase-host.pooler.supabase.com
SEGURIDAD_DB_PORT=5432
SEGURIDAD_DB_USER=postgres.yourprojectid
SEGURIDAD_DB_PASS=YOUR_DB_PASSWORD_HERE
SEGURIDAD_DB_NAME=postgres

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
